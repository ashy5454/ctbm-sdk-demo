{
  "name": "@ctbm/core",
  "version": "0.1.0",
  "description": "Core classifier, router, memory, and types for the CTBM SDK",
  "keywords": ["ctbm", "monetization", "conversation", "ai", "classifier"],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@ctbm/storage": "*"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  }
}
